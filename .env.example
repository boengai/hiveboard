# GitHub org or user that owns the project (required)
GITHUB_OWNER=your-org

# GitHub Projects V2 board number (required)
# e.g. for github.com/orgs/your-org/projects/5, set this to 5
GITHUB_PROJECT_NUMBER=1

# GitHub personal access token (required)
# Needs scopes: project, repo, issues
GITHUB_TOKEN=ghp_your_token_here

# GitHub App auth (alternative to PAT — set these and remove GITHUB_TOKEN):
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_INSTALLATION_ID=12345678

# GitHub webhook secret (optional, but recommended)
# Must match the secret configured in your repo's webhook settings
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── Docker Compose ────────────────────────────────────
# Webhook server port (optional, defaults to 8080)
WEBHOOK_PORT=8080

# ── Cloudflare Tunnel (built-in, optional) ────────────
# Set to "true" for a free quick tunnel (random *.trycloudflare.com URL)
CLOUDFLARE_TUNNEL=true

# Named tunnel token (use instead of quick tunnel if you have a domain)
# Get from: Cloudflare Zero Trust > Networks > Tunnels > Create
# CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoi...
